# gana-v8 runtime defaults
# Copy to .env and adjust only what your local slice needs.

# Shared database URL used by Prisma and by config-runtime when GANA_DATABASE_URL is not set.
# Default local-dev direction: Managed MySQL in DigitalOcean (TLS required).
# For DigitalOcean managed MySQL without a custom CA bundle, use sslaccept=accept_invalid_certs.
DATABASE_URL=mysql://USER:***@HOST:25060/gana_v8_ops_20260415_1752?sslaccept=accept_invalid_certs

# Optional admin URL for schema/bootstrap tasks that need broader privileges.
DATABASE_ADMIN_URL=mysql://USER:***@HOST:25060/mysql?sslaccept=accept_invalid_certs

# Optional namespaced override for runtime config loaders.
# GANA_DATABASE_URL=mysql://USER:***@HOST:25060/gana_v8_ops_20260415_1752?sslaccept=accept_invalid_certs

# App environment and runtime profile.
# Supported GANA_APP_ENV values: development, test, staging, production
GANA_APP_ENV=development
# Supported GANA_RUNTIME_PROFILE values:
# local-dev, ci-smoke, ci-regression, staging-like, historical-backtest, production
GANA_RUNTIME_PROFILE=local-dev

# Provider routing for demo and sandbox-style runtime slices.
# Supported GANA_PROVIDER_SOURCE values: mock, replay, live-readonly
GANA_PROVIDER_SOURCE=mock
GANA_PROVIDER_BASE_URL=mock://api-football

# API-Football live readonly connector.
# Set GANA_PROVIDER_SOURCE=live-readonly and provide a key to enable real reads.
# GANA_API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY
# Optional aliases also supported by ingestion-worker: API_FOOTBALL_KEY, APIFOOTBALL_API_KEY, RAPIDAPI_KEY
# Optional host override defaults to api-football-v1.p.rapidapi.com
# GANA_API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com
# Optional timeout override in milliseconds
# GANA_API_FOOTBALL_TIMEOUT_MS=15000
# Optional declarative live runner overrides
# GANA_FOOTBALL_LEAGUE=39
# GANA_FOOTBALL_SEASON=2025
# GANA_FOOTBALL_MARKET_KEYS=h2h
# GANA_LIVE_ODDS_FIXTURE_IDS=1499235,1499236
# GANA_FOOTBALL_FIXTURES_WINDOW_START=2026-04-20T00:00:00.000Z
# GANA_FOOTBALL_FIXTURES_WINDOW_END=2026-04-21T00:00:00.000Z
# GANA_FOOTBALL_FIXTURES_WINDOW_GRANULARITY=daily
# GANA_FOOTBALL_ODDS_WINDOW_START=2026-04-20T11:45:00.000Z
# GANA_FOOTBALL_ODDS_WINDOW_END=2026-04-20T13:30:00.000Z
# GANA_FOOTBALL_ODDS_WINDOW_GRANULARITY=intraday

# AI research/scoring synthesis.
# Web search modes: disabled, auto, required. When auto/required is set, the Codex HTTP
# provider sends the OpenAI Responses web_search_preview tool and matching tool_choice.
# GANA_RESEARCH_SYNTHESIS_MODE=ai-assisted
# GANA_ENABLE_RESEARCH_AI=1
# GANA_RESEARCH_AI_MODEL=gpt-5.4
# GANA_RESEARCH_AI_REASONING=medium
# GANA_RESEARCH_WEB_SEARCH_MODE=auto
# GANA_SCORING_SYNTHESIS_MODE=ai-assisted
# GANA_ENABLE_SCORING_AI=1
# GANA_SCORING_AI_MODEL=gpt-5.4
# GANA_SCORING_AI_REASONING=medium
# GANA_SCORING_WEB_SEARCH_MODE=auto

# Logging and execution toggles.
# Supported GANA_LOG_LEVEL values: debug, info, warn, error
GANA_LOG_LEVEL=debug
GANA_DRY_RUN=true
GANA_DEMO_MODE=true

# Public API auth tokens. If set, public-api requires Bearer tokens for reads and writes.
# Viewer tokens can read; operator tokens can also apply workflow overrides.
# GANA_PUBLIC_API_VIEWER_TOKEN=replace-with-viewer-token
# GANA_PUBLIC_API_OPERATOR_TOKEN=replace-with-operator-token
# Optional automation/system tokens for service-to-service access.
# GANA_PUBLIC_API_AUTOMATION_TOKEN=replace-with-automation-token
# GANA_PUBLIC_API_SYSTEM_TOKEN=replace-with-system-token
# Optional realm label returned in WWW-Authenticate headers.
# GANA_PUBLIC_API_AUTH_REALM=gana-v8-public-api
# Optional filesystem roots for sandbox certification reads.
# GANA_SANDBOX_GOLDENS_ROOT=fixtures/replays/goldens
# GANA_SANDBOX_CERT_ARTIFACTS_ROOT=.artifacts/sandbox-certification

# Public API bind settings when running `pnpm --filter @gana-v8/public-api serve`
# GANA_PUBLIC_API_HOST=127.0.0.1
# GANA_PUBLIC_API_PORT=3100

# Operator console web bind settings and upstream API wiring when running
# `pnpm --filter @gana-v8/operator-console serve:web`
# GANA_OPERATOR_CONSOLE_HOST=127.0.0.1
# GANA_OPERATOR_CONSOLE_PORT=3200
# GANA_OPERATOR_CONSOLE_PUBLIC_API_URL=http://127.0.0.1:3100
# GANA_OPERATOR_CONSOLE_PUBLIC_API_TOKEN=replace-with-operator-or-viewer-token
