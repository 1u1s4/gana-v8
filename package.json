{
  "name": "gana-v8",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.30.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --skip-generate --schema prisma/schema.prisma",
    "db:validate": "prisma validate --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:reset": "prisma migrate reset --force --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "lint": "node scripts/workspace-lint.mjs --repo . && turbo run lint",
    "ops-history-retention": "tsx scripts/ops-history-retention.ts",
    "test": "turbo run test",
    "test:e2e": "pnpm test:e2e:hermes-smoke",
    "test:e2e:hermes-smoke": "node tests/e2e/hermes-smoke.mjs",
    "test:sandbox": "pnpm test:sandbox:certification",
    "test:sandbox:certification": "node tests/sandbox/certification.mjs",
    "test:runtime:release": "node tests/sandbox/runtime-release.mjs",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@prisma/client": "6.16.2",
    "@types/node": "^24.6.0",
    "prettier": "^3.6.2",
    "prisma": "^6.16.2",
    "tsx": "^4.20.6",
    "turbo": "^2.5.5",
    "typescript": "^5.9.2"
  }
}
