generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Environment {
  prod
  staging
  sandbox
}

enum FixtureStatus {
  scheduled
  live
  completed
  cancelled
}

enum TaskKind {
  fixture_ingestion @map("fixture-ingestion")
  odds_ingestion    @map("odds-ingestion")
  research
  prediction
  validation
  sandbox_replay    @map("sandbox-replay")
}

enum TaskStatus {
  queued
  running
  succeeded
  failed
  quarantined
  cancelled
}

enum TaskRunStatus {
  running
  succeeded
  failed
  cancelled
}

enum TaskTriggerKind {
  cron
  manual
  retry
  system
}

enum AutomationCycleKind {
  scheduler
  dispatcher
  recovery
}

enum AutomationCycleStatus {
  running
  succeeded
  failed
}

enum AiRunStatus {
  pending
  running
  completed
  failed
}

enum PredictionStatus {
  draft
  published
  settled
  voided
}

enum PredictionMarket {
  moneyline
  totals
  spread
  both_teams_score @map("both-teams-score")
}

enum PredictionOutcome {
  home
  away
  draw
  over
  under
  yes
  no
}

enum ParlayStatus {
  draft
  ready
  submitted
  settled
  voided
}

enum ParlaySource {
  manual
  automatic
}

enum ParlayLegStatus {
  pending
  won
  lost
  voided
}

enum ValidationStatus {
  pending
  passed
  failed
  partial
}

enum ValidationKind {
  fixture_result        @map("fixture-result")
  prediction_settlement @map("prediction-settlement")
  parlay_settlement     @map("parlay-settlement")
  sandbox_regression    @map("sandbox-regression")
}

enum ValidationTargetType {
  fixture
  task
  task_run          @map("task-run")
  ai_run            @map("ai-run")
  prediction
  parlay
  audit_event       @map("audit-event")
  sandbox_namespace @map("sandbox-namespace")
}

enum WorkflowStageStatus {
  pending
  running
  succeeded
  failed
  skipped
  blocked
}

enum FixtureManualSelectionStatus {
  none
  selected
  rejected
}

enum FixtureSelectionOverride {
  none
  force_include @map("force-include")
  force_exclude @map("force-exclude")
}

model Fixture {
  id                   String                 @id
  sport                String
  competition          String
  homeTeam             String
  awayTeam             String
  scheduledAt          DateTime
  status               FixtureStatus
  scoreHome            Int?
  scoreAway            Int?
  metadata             Json
  predictions          Prediction[]
  parlayLegs           ParlayLeg[]
  oddsSnapshots        OddsSnapshot[]
  researchBundles      ResearchBundle[]
  researchSources      ResearchSource[]
  researchClaims       ResearchClaim[]
  researchConflicts    ResearchConflict[]
  featureSnapshots     FeatureSnapshot[]
  availabilitySnapshots AvailabilitySnapshot[]
  lineupSnapshots      LineupSnapshot[]
  researchAssignments  ResearchAssignment[]
  workflow             FixtureWorkflow?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([competition, scheduledAt])
}

model FixtureWorkflow {
  id               String              @id
  fixtureId        String              @unique
  fixture          Fixture             @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  ingestionStatus  WorkflowStageStatus
  oddsStatus       WorkflowStageStatus
  enrichmentStatus WorkflowStageStatus
  candidateStatus  WorkflowStageStatus
  predictionStatus WorkflowStageStatus
  parlayStatus     WorkflowStageStatus
  validationStatus WorkflowStageStatus
  isCandidate      Boolean
  minDetectedOdd   Float?
  qualityScore     Float?
  selectionScore   Float?
  lastIngestedAt   DateTime?
  lastEnrichedAt   DateTime?
  lastPredictedAt  DateTime?
  lastParlayAt     DateTime?
  lastValidatedAt  DateTime?
  manualSelectionStatus FixtureManualSelectionStatus @default(none)
  manualSelectionBy String?
  manualSelectionReason String?
  manuallySelectedAt DateTime?
  selectionOverride FixtureSelectionOverride @default(none)
  overrideReason String?
  overriddenAt DateTime?
  errorCount       Int                 @default(0)
  lastErrorMessage String?             @db.Text
  diagnostics      Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([fixtureId, updatedAt])
  @@index([predictionStatus])
  @@index([validationStatus])
}

model RawIngestionBatch {
  id                    String                @id
  providerCode          String
  endpointFamily        String
  sourceName            String
  sourceEndpoint        String
  runId                 String
  schemaVersion         String
  fetchedAt             DateTime
  extractionTime        DateTime
  coverageWindowStart   DateTime
  coverageWindowEnd     DateTime
  coverageGranularity   String
  checksum              String
  extractionStatus      String
  warnings              Json
  sourceQualityScore    Float
  recordCount           Int
  rawObjectRefs         Json
  oddsSnapshots         OddsSnapshot[]
  availabilitySnapshots AvailabilitySnapshot[]
  lineupSnapshots       LineupSnapshot[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([providerCode, endpointFamily, extractionTime])
}

model OddsSnapshot {
  id                String                  @id
  batchId           String
  batch             RawIngestionBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fixtureId         String?
  fixture           Fixture?                @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  providerFixtureId String
  providerCode      String
  bookmakerKey      String
  marketKey         String
  capturedAt        DateTime
  payload           Json
  selections        OddsSelectionSnapshot[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([batchId, providerFixtureId, bookmakerKey, marketKey])
  @@index([fixtureId, capturedAt])
}

model OddsSelectionSnapshot {
  id             String       @id
  oddsSnapshotId String
  oddsSnapshot   OddsSnapshot @relation(fields: [oddsSnapshotId], references: [id], onDelete: Cascade)
  index          Int
  selectionKey   String
  label          String
  priceDecimal   Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([oddsSnapshotId, index])
  @@index([selectionKey])
}

model Task {
  id               String          @id
  kind             TaskKind
  status           TaskStatus
  triggerKind      TaskTriggerKind @default(system)
  priority         Int
  dedupeKey        String?
  manifestId       String?
  workflowId       String?
  traceId          String?
  correlationId    String?
  source           String?
  payload          Json
  scheduledFor     DateTime?
  maxAttempts      Int             @default(3)
  lastErrorMessage String?         @db.Text
  leaseOwner       String?
  leaseExpiresAt   DateTime?
  claimedAt        DateTime?
  lastHeartbeatAt  DateTime?
  activeTaskRunId  String?
  taskRuns         TaskRun[]
  aiRuns           AiRun[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status, createdAt])
  @@index([status, leaseExpiresAt])
  @@index([dedupeKey])
  @@index([manifestId, createdAt])
  @@index([workflowId, createdAt])
  @@index([traceId])
  @@index([correlationId])
  @@index([activeTaskRunId])
}

model TaskRun {
  id                String        @id
  taskId            String
  task              Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attemptNumber     Int
  status            TaskRunStatus
  workerName        String?
  startedAt         DateTime
  finishedAt        DateTime?
  error             String?       @db.Text
  result            Json?
  retryScheduledFor DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([taskId, attemptNumber])
  @@index([taskId, startedAt])
}

model AutomationCycle {
  id         String                @id
  kind       AutomationCycleKind
  status     AutomationCycleStatus
  leaseOwner String
  summary    Json?
  metadata   Json?
  error      String?               @db.Text
  startedAt  DateTime
  finishedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([kind, startedAt])
  @@index([status, startedAt])
  @@index([leaseOwner, startedAt])
}

model SchedulerCursor {
  id              String   @id
  specId          String   @unique
  lastTriggeredAt DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([lastTriggeredAt])
}

model AiRun {
  id                    String       @id
  taskId                String
  task                  Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  provider              String
  model                 String
  promptVersion         String
  status                AiRunStatus
  providerRequestId     String?
  usagePromptTokens     Int?
  usageCompletionTokens Int?
  usageTotalTokens      Int?
  outputRef             String?
  error                 String?       @db.Text
  fallbackReason        String?       @db.Text
  degraded              Boolean?
  predictions           Prediction[]
  researchBundles       ResearchBundle[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([taskId, createdAt])
}

model ResearchBundle {
  id               String            @id
  fixtureId        String
  fixture          Fixture           @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  generatedAt      DateTime
  gatedAt          DateTime
  status           String
  briefHeadline    String
  briefContext     String            @db.Text
  briefQuestions   Json
  briefAssumptions Json
  summary          String            @db.Text
  recommendedLean  String
  directionalScore Json
  risks            Json
  gateReasons      Json
  trace            Json?
  aiRunId          String?
  aiRun            AiRun?            @relation(fields: [aiRunId], references: [id], onDelete: SetNull)
  claims           ResearchClaim[]
  sources          ResearchSource[]
  conflicts        ResearchConflict[]
  featureSnapshots FeatureSnapshot[]
  assignments      ResearchAssignment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([fixtureId, generatedAt])
  @@index([status, generatedAt])
}

model ResearchSource {
  id                 String                @id
  bundleId           String
  bundle             ResearchBundle        @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  fixtureId          String
  fixture            Fixture               @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  provider           String
  reference          String
  sourceType         String
  title              String?
  url                String?               @db.Text
  admissibility      String
  independenceKey    String
  capturedAt         DateTime
  publishedAt        DateTime?
  freshnessExpiresAt DateTime?
  metadata           Json
  claimLinks         ResearchClaimSource[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([bundleId, capturedAt])
  @@index([fixtureId, admissibility])
}

model ResearchClaim {
  id                  String                @id
  bundleId            String
  bundle              ResearchBundle        @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  fixtureId           String
  fixture             Fixture               @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  assignmentId        String?
  assignment          ResearchAssignment?   @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  kind                String
  title               String
  summary             String                @db.Text
  direction           String
  confidence          Float
  impact              Float
  significance        String
  status              String
  corroborationStatus String
  requiredSourceCount Int
  matchedSourceIds    Json
  freshnessWindowHours Int
  extractedAt         DateTime
  freshnessExpiresAt  DateTime?
  metadata            Json
  sourceLinks         ResearchClaimSource[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([bundleId, kind])
  @@index([fixtureId, extractedAt])
}

model ResearchClaimSource {
  id         String         @id
  claimId    String
  claim      ResearchClaim  @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sourceId   String
  source     ResearchSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  orderIndex Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([claimId, sourceId])
  @@index([sourceId])
}

model ResearchConflict {
  id             String         @id
  bundleId       String
  bundle         ResearchBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  fixtureId      String
  fixture        Fixture        @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  claimIds       Json
  summary        String         @db.Text
  severity       String
  status         String
  resolutionNote String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([bundleId, severity])
  @@index([fixtureId, status])
}

model FeatureSnapshot {
  id               String         @id
  fixtureId        String
  fixture          Fixture        @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  bundleId         String
  bundle           ResearchBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  generatedAt      DateTime
  bundleStatus     String
  gateReasons      Json
  recommendedLean  String
  evidenceCount    Int
  topEvidence      Json
  risks            Json
  features         Json
  readinessStatus  String
  readinessReasons Json
  researchTrace    Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([fixtureId, generatedAt])
  @@index([bundleId, generatedAt])
}

model AvailabilitySnapshot {
  id               String            @id
  batchId          String
  batch            RawIngestionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fixtureId        String?
  fixture          Fixture?          @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  providerFixtureId String
  providerCode     String
  teamSide         String?           @db.VarChar(32)
  subjectType      String            @db.VarChar(32)
  subjectName      String            @db.VarChar(128)
  status           String
  capturedAt       DateTime
  sourceUpdatedAt  DateTime?
  summary          String            @db.Text
  payload          Json
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([batchId, providerFixtureId, teamSide, subjectType, subjectName])
  @@index([fixtureId, capturedAt])
}

model LineupSnapshot {
  id               String             @id
  batchId          String
  batch            RawIngestionBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fixtureId        String?
  fixture          Fixture?           @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  providerFixtureId String
  providerCode     String
  teamSide         String             @db.VarChar(32)
  lineupStatus     String             @db.VarChar(64)
  formation        String?
  capturedAt       DateTime
  sourceUpdatedAt  DateTime?
  payload          Json
  participants     LineupParticipant[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([batchId, providerFixtureId, teamSide, lineupStatus])
  @@index([fixtureId, capturedAt])
}

model LineupParticipant {
  id                 String        @id
  lineupSnapshotId   String
  lineupSnapshot     LineupSnapshot @relation(fields: [lineupSnapshotId], references: [id], onDelete: Cascade)
  index              Int
  participantName    String
  role               String
  position           String?
  jerseyNumber       Int?
  availabilityStatus String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([lineupSnapshotId, index])
  @@index([participantName])
}

model ResearchAssignment {
  id            String         @id
  fixtureId     String
  fixture       Fixture        @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  bundleId      String?
  bundle        ResearchBundle? @relation(fields: [bundleId], references: [id], onDelete: SetNull)
  dimension     String
  status        String
  attemptNumber Int
  startedAt     DateTime?
  finishedAt    DateTime?
  error         String?        @db.Text
  summary       String?        @map("outputSummary") @db.Text
  metadata      Json
  claims        ResearchClaim[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([fixtureId, createdAt])
  @@index([bundleId, dimension])
}

model Prediction {
  id            String            @id
  fixtureId     String
  fixture       Fixture           @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  aiRunId       String?
  aiRun         AiRun?            @relation(fields: [aiRunId], references: [id], onDelete: SetNull)
  market        PredictionMarket
  outcome       PredictionOutcome
  status        PredictionStatus
  confidence    Float
  probabilities Json
  rationale     Json
  publishedAt   DateTime?
  settledAt     DateTime?
  parlayLegs    ParlayLeg[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([fixtureId, createdAt])
  @@index([aiRunId])
}

model Parlay {
  id               String       @id
  status           ParlayStatus
  stake            Float
  source           ParlaySource
  correlationScore Float
  expectedPayout   Float
  submittedAt      DateTime?
  settledAt        DateTime?
  legs             ParlayLeg[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ParlayLeg {
  id           String          @id
  parlayId     String
  parlay       Parlay          @relation(fields: [parlayId], references: [id], onDelete: Cascade)
  predictionId String
  prediction   Prediction      @relation(fields: [predictionId], references: [id], onDelete: Restrict)
  fixtureId    String
  fixture      Fixture         @relation(fields: [fixtureId], references: [id], onDelete: Restrict)
  index        Int
  market       String
  outcome      String
  price        Float
  status       ParlayLegStatus

  @@unique([parlayId, index])
  @@index([predictionId])
  @@index([fixtureId])
}

model Validation {
  id         String               @id
  targetType ValidationTargetType
  targetId   String
  kind       ValidationKind
  status     ValidationStatus
  checks     Json
  summary    String               @db.Text
  executedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([targetType, targetId, createdAt])
}

model AuditEvent {
  id            String   @id
  aggregateType String
  aggregateId   String
  eventType     String
  actor         String?
  payload       Json
  occurredAt    DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([aggregateType, aggregateId, occurredAt])
}

model LeagueCoveragePolicy {
  id             String   @id
  provider       String
  leagueKey      String
  leagueName     String
  season         Int
  enabled        Boolean
  alwaysOn       Boolean
  priority       Int
  marketsAllowed Json
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([provider, leagueKey, season])
  @@index([enabled, priority, leagueName])
}

model TeamCoveragePolicy {
  id            String   @id
  provider      String
  teamKey       String
  teamName      String
  enabled       Boolean
  alwaysTrack   Boolean
  priority      Int
  followHome    Boolean
  followAway    Boolean
  forceResearch Boolean
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider, teamKey])
  @@index([enabled, priority, teamName])
}

model DailyAutomationPolicy {
  id                       String   @id
  policyName               String   @unique
  enabled                  Boolean
  timezone                 String
  minAllowedOdd            Float
  defaultMaxFixturesPerRun Int
  defaultLookaheadHours    Int
  defaultLookbackHours     Int
  requireTrackedLeagueOrTeam Boolean
  allowManualInclusionBypass Boolean
  notes                    String?  @db.Text
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([enabled, policyName])
}

model SandboxNamespace {
  id            String      @id
  environment   Environment
  sandboxId     String?
  scope         String
  storagePrefix String
  queuePrefix   String
  metadata      Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([environment, sandboxId, scope])
  @@index([environment, createdAt])
}
