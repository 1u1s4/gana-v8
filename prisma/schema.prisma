generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Environment {
  prod
  staging
  sandbox
}

enum FixtureStatus {
  scheduled
  live
  completed
  cancelled
}

enum TaskKind {
  fixture_ingestion @map("fixture-ingestion")
  odds_ingestion    @map("odds-ingestion")
  research
  prediction
  validation
  sandbox_replay    @map("sandbox-replay")
}

enum TaskStatus {
  queued
  running
  succeeded
  failed
  quarantined
  cancelled
}

enum TaskRunStatus {
  running
  succeeded
  failed
  cancelled
}

enum TaskTriggerKind {
  cron
  manual
  retry
  system
}

enum AiRunStatus {
  pending
  running
  completed
  failed
}

enum PredictionStatus {
  draft
  published
  settled
  voided
}

enum PredictionMarket {
  moneyline
  totals
  spread
  both_teams_score @map("both-teams-score")
}

enum PredictionOutcome {
  home
  away
  draw
  over
  under
  yes
  no
}

enum ParlayStatus {
  draft
  ready
  submitted
  settled
  voided
}

enum ParlaySource {
  manual
  automatic
}

enum ParlayLegStatus {
  pending
  won
  lost
  voided
}

enum ValidationStatus {
  pending
  passed
  failed
  partial
}

enum ValidationKind {
  fixture_result        @map("fixture-result")
  prediction_settlement @map("prediction-settlement")
  parlay_settlement     @map("parlay-settlement")
  sandbox_regression    @map("sandbox-regression")
}

enum ValidationTargetType {
  fixture
  task
  task_run          @map("task-run")
  ai_run            @map("ai-run")
  prediction
  parlay
  audit_event       @map("audit-event")
  sandbox_namespace @map("sandbox-namespace")
}

enum WorkflowStageStatus {
  pending
  running
  succeeded
  failed
  skipped
  blocked
}

enum FixtureManualSelectionStatus {
  none
  selected
  rejected
}

enum FixtureSelectionOverride {
  none
  force_include @map("force-include")
  force_exclude @map("force-exclude")
}

model Fixture {
  id            String           @id
  sport         String
  competition   String
  homeTeam      String
  awayTeam      String
  scheduledAt   DateTime
  status        FixtureStatus
  scoreHome     Int?
  scoreAway     Int?
  metadata      Json
  predictions   Prediction[]
  parlayLegs    ParlayLeg[]
  oddsSnapshots OddsSnapshot[]
  workflow      FixtureWorkflow?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([competition, scheduledAt])
}

model FixtureWorkflow {
  id               String              @id
  fixtureId        String              @unique
  fixture          Fixture             @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  ingestionStatus  WorkflowStageStatus
  oddsStatus       WorkflowStageStatus
  enrichmentStatus WorkflowStageStatus
  candidateStatus  WorkflowStageStatus
  predictionStatus WorkflowStageStatus
  parlayStatus     WorkflowStageStatus
  validationStatus WorkflowStageStatus
  isCandidate      Boolean
  minDetectedOdd   Float?
  qualityScore     Float?
  selectionScore   Float?
  lastIngestedAt   DateTime?
  lastEnrichedAt   DateTime?
  lastPredictedAt  DateTime?
  lastParlayAt     DateTime?
  lastValidatedAt  DateTime?
  manualSelectionStatus FixtureManualSelectionStatus @default(none)
  manualSelectionBy String?
  manualSelectionReason String?
  manuallySelectedAt DateTime?
  selectionOverride FixtureSelectionOverride @default(none)
  overrideReason String?
  overriddenAt DateTime?
  errorCount       Int                 @default(0)
  lastErrorMessage String?             @db.Text
  diagnostics      Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([fixtureId, updatedAt])
  @@index([predictionStatus])
  @@index([validationStatus])
}

model RawIngestionBatch {
  id                  String         @id
  providerCode        String
  endpointFamily      String
  sourceName          String
  sourceEndpoint      String
  runId               String
  schemaVersion       String
  fetchedAt           DateTime
  extractionTime      DateTime
  coverageWindowStart DateTime
  coverageWindowEnd   DateTime
  coverageGranularity String
  checksum            String
  extractionStatus    String
  warnings            Json
  sourceQualityScore  Float
  recordCount         Int
  rawObjectRefs       Json
  oddsSnapshots       OddsSnapshot[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([providerCode, endpointFamily, extractionTime])
}

model OddsSnapshot {
  id                String                  @id
  batchId           String
  batch             RawIngestionBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fixtureId         String?
  fixture           Fixture?                @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  providerFixtureId String
  providerCode      String
  bookmakerKey      String
  marketKey         String
  capturedAt        DateTime
  payload           Json
  selections        OddsSelectionSnapshot[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([batchId, providerFixtureId, bookmakerKey, marketKey])
  @@index([fixtureId, capturedAt])
}

model OddsSelectionSnapshot {
  id             String       @id
  oddsSnapshotId String
  oddsSnapshot   OddsSnapshot @relation(fields: [oddsSnapshotId], references: [id], onDelete: Cascade)
  index          Int
  selectionKey   String
  label          String
  priceDecimal   Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([oddsSnapshotId, index])
  @@index([selectionKey])
}

model Task {
  id               String          @id
  kind             TaskKind
  status           TaskStatus
  triggerKind      TaskTriggerKind @default(system)
  priority         Int
  dedupeKey        String?
  payload          Json
  scheduledFor     DateTime?
  maxAttempts      Int             @default(3)
  lastErrorMessage String?         @db.Text
  taskRuns         TaskRun[]
  aiRuns           AiRun[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status, createdAt])
  @@index([dedupeKey])
}

model TaskRun {
  id                String        @id
  taskId            String
  task              Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attemptNumber     Int
  status            TaskRunStatus
  workerName        String?
  startedAt         DateTime
  finishedAt        DateTime?
  error             String?       @db.Text
  result            Json?
  retryScheduledFor DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([taskId, attemptNumber])
  @@index([taskId, startedAt])
}

model AiRun {
  id                    String       @id
  taskId                String
  task                  Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  provider              String
  model                 String
  promptVersion         String
  status                AiRunStatus
  providerRequestId     String?
  usagePromptTokens     Int?
  usageCompletionTokens Int?
  usageTotalTokens      Int?
  outputRef             String?
  error                 String?       @db.Text
  fallbackReason        String?       @db.Text
  degraded              Boolean?
  predictions           Prediction[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([taskId, createdAt])
}

model Prediction {
  id            String            @id
  fixtureId     String
  fixture       Fixture           @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  aiRunId       String?
  aiRun         AiRun?            @relation(fields: [aiRunId], references: [id], onDelete: SetNull)
  market        PredictionMarket
  outcome       PredictionOutcome
  status        PredictionStatus
  confidence    Float
  probabilities Json
  rationale     Json
  publishedAt   DateTime?
  settledAt     DateTime?
  parlayLegs    ParlayLeg[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([fixtureId, createdAt])
  @@index([aiRunId])
}

model Parlay {
  id               String       @id
  status           ParlayStatus
  stake            Float
  source           ParlaySource
  correlationScore Float
  expectedPayout   Float
  submittedAt      DateTime?
  settledAt        DateTime?
  legs             ParlayLeg[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ParlayLeg {
  id           String          @id
  parlayId     String
  parlay       Parlay          @relation(fields: [parlayId], references: [id], onDelete: Cascade)
  predictionId String
  prediction   Prediction      @relation(fields: [predictionId], references: [id], onDelete: Restrict)
  fixtureId    String
  fixture      Fixture         @relation(fields: [fixtureId], references: [id], onDelete: Restrict)
  index        Int
  market       String
  outcome      String
  price        Float
  status       ParlayLegStatus

  @@unique([parlayId, index])
  @@index([predictionId])
  @@index([fixtureId])
}

model Validation {
  id         String               @id
  targetType ValidationTargetType
  targetId   String
  kind       ValidationKind
  status     ValidationStatus
  checks     Json
  summary    String               @db.Text
  executedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([targetType, targetId, createdAt])
}

model AuditEvent {
  id            String   @id
  aggregateType String
  aggregateId   String
  eventType     String
  actor         String?
  payload       Json
  occurredAt    DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([aggregateType, aggregateId, occurredAt])
}

model LeagueCoveragePolicy {
  id             String   @id
  provider       String
  leagueKey      String
  leagueName     String
  season         Int
  enabled        Boolean
  alwaysOn       Boolean
  priority       Int
  marketsAllowed Json
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([provider, leagueKey, season])
  @@index([enabled, priority, leagueName])
}

model TeamCoveragePolicy {
  id            String   @id
  provider      String
  teamKey       String
  teamName      String
  enabled       Boolean
  alwaysTrack   Boolean
  priority      Int
  followHome    Boolean
  followAway    Boolean
  forceResearch Boolean
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider, teamKey])
  @@index([enabled, priority, teamName])
}

model DailyAutomationPolicy {
  id                       String   @id
  policyName               String   @unique
  enabled                  Boolean
  timezone                 String
  minAllowedOdd            Float
  defaultMaxFixturesPerRun Int
  defaultLookaheadHours    Int
  defaultLookbackHours     Int
  requireTrackedLeagueOrTeam Boolean
  allowManualInclusionBypass Boolean
  notes                    String?  @db.Text
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([enabled, policyName])
}

model SandboxNamespace {
  id            String      @id
  environment   Environment
  sandboxId     String?
  scope         String
  storagePrefix String
  queuePrefix   String
  metadata      Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([environment, sandboxId, scope])
  @@index([environment, createdAt])
}
