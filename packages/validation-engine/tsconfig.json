    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@gana-v8/domain-core": ["../domain-core/dist/src/index.d.ts"],
      "@gana-v8/parlay-engine": ["../parlay-engine/dist/index.d.ts"],
