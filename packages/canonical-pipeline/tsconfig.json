{
  "extends": "../../tsconfig.package.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@gana-v8/domain-core": ["../domain-core/dist/src/index.d.ts"],
      "@gana-v8/contract-schemas": ["../contract-schemas/dist/src/index.d.ts"],
      "@gana-v8/source-connectors": ["../source-connectors/dist/index.d.ts"]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
