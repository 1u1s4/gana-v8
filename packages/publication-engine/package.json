{
  "name": "@gana-v8/publication-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Formatting and publication readiness placeholders for downstream channels.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @gana-v8/authz build && tsc -p tsconfig.build.json",
    "dev": "node ../../scripts/workspace-dev.mjs publication-engine",
    "lint": "node ../../scripts/workspace-lint.mjs .",
    "test": "node ../../scripts/workspace-test.mjs .",
    "typecheck": "pnpm --filter @gana-v8/authz build && tsc -p tsconfig.json --noEmit",
    "clean": "node --eval \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }))\""
  },
  "dependencies": {
    "@gana-v8/authz": "workspace:*",
    "@gana-v8/prediction-engine": "workspace:*",
    "@gana-v8/policy-engine": "workspace:*"
  }
}
