{
  "name": "@gana-v8/scoring-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Builds features and prediction artifacts for scheduled scoring runs.",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node ../../scripts/workspace-dev.mjs scoring-worker",
    "lint": "node ../../scripts/workspace-lint.mjs .",
    "test": "tsx --tsconfig ../../tsconfig.base.json --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node --eval \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }))\""
  },
  "dependencies": {
    "@gana-v8/config-runtime": "workspace:*",
    "@gana-v8/domain-core": "workspace:*",
    "@gana-v8/feature-store": "workspace:*",
    "@gana-v8/observability": "workspace:*",
    "@gana-v8/prediction-engine": "workspace:*",
    "@gana-v8/storage-adapters": "workspace:*"
  }
}
