{
  "name": "@gana-v8/sandbox-runner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Isolated sandbox execution entrypoint for replay and experiment workflows.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node ../../scripts/workspace-dev.mjs sandbox-runner",
    "lint": "node ../../scripts/workspace-lint.mjs .",
    "test": "node ../../scripts/workspace-test.mjs .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node --eval \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }))\""
  },
  "dependencies": {
    "@gana-v8/dev-cli": "workspace:*",
    "@gana-v8/testing-fixtures": "workspace:*",
    "@gana-v8/config-runtime": "workspace:*",
    "@gana-v8/observability": "workspace:*"
  }
}
